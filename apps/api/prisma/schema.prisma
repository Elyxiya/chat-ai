// This is your Prisma schema file
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(uuid())
  username      String    @unique @db.VarChar(50)
  email         String    @unique @db.VarChar(100)
  passwordHash  String    @map("password_hash") @db.VarChar(255)
  nickname      String?   @db.VarChar(100)
  avatarUrl     String?   @map("avatar_url") @db.Text
  bio           String?   @db.Text
  userType      String    @default("human") @map("user_type") @db.VarChar(20)
  status        String    @default("offline") @db.VarChar(20)
  lastSeenAt    DateTime? @map("last_seen_at")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  oauthAccounts    OAuthAccount[]
  refreshTokens    RefreshToken[]
  sessions         UserSession[]
  friendships      Friendship[]         @relation("UserFriendships")
  friendOf         Friendship[]         @relation("FriendOfFriendships")
  ownedSessions    ChatSession[]        @relation("SessionOwner")
  sessionMembers   ChatSessionMember[]
  sentMessages     Message[]
  recalledMessages Message[]            @relation("RecalledBy")
  reactions        MessageReaction[]
  mentions         MessageMention[]
  agentMemories    AgentMemory[]
  conversations    AgentConversation[]
  toolLogs         AgentToolLog[]
  metrics          AgentMetric[]
  uploads          FileUpload[]
  notifications    Notification[]
  auditLogs        AuditLog[]
  knowledgeBases   KnowledgeBase[]

  @@map("users")
}

model OAuthAccount {
  id               String    @id @default(uuid())
  userId           String    @map("user_id")
  provider         String    @db.VarChar(50)
  providerUserId   String    @map("provider_user_id") @db.VarChar(255)
  accessToken      String?   @map("access_token") @db.Text
  refreshToken     String?   @map("refresh_token") @db.Text
  tokenExpiresAt   DateTime? @map("token_expires_at")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerUserId])
  @@map("oauth_accounts")
}

model RefreshToken {
  id        String    @id @default(uuid())
  userId    String    @map("user_id")
  tokenHash String    @map("token_hash") @db.VarChar(255)
  expiresAt DateTime  @map("expires_at")
  createdAt DateTime  @default(now()) @map("created_at")
  revokedAt DateTime? @map("revoked_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tokenHash])
  @@map("refresh_tokens")
}

model UserSession {
  id          String    @id @default(uuid())
  userId      String    @map("user_id")
  deviceInfo  String?   @map("device_info") @db.VarChar(255)
  ipAddress   String?   @map("ip_address") @db.VarChar(45)
  lastActiveAt DateTime @default(now()) @map("last_active_at")
  createdAt   DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_sessions")
}

model Friendship {
  id        String    @id @default(uuid())
  userId    String    @map("user_id")
  friendId  String    @map("friend_id")
  status    String    @default("pending") @db.VarChar(20)
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  user   User @relation("UserFriendships", fields: [userId], references: [id], onDelete: Cascade)
  friend User @relation("FriendOfFriendships", fields: [friendId], references: [id], onDelete: Cascade)

  @@unique([userId, friendId])
  @@map("friendships")
}

model ChatSession {
  id          String    @id @default(uuid())
  sessionType String    @map("session_type") @db.VarChar(20)
  name        String?   @db.VarChar(100)
  description String?   @db.Text
  avatarUrl   String?   @map("avatar_url") @db.Text
  ownerId     String?   @map("owner_id")
  isPublic    Boolean   @default(false) @map("is_public")
  maxMembers  Int       @default(500) @map("max_members")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  owner    User?               @relation("SessionOwner", fields: [ownerId], references: [id], onDelete: SetNull)
  members  ChatSessionMember[]
  messages Message[]
  agentMemories AgentMemory[]
  conversations AgentConversation[]

  @@map("chat_sessions")
}

model ChatSessionMember {
  id         String    @id @default(uuid())
  sessionId  String    @map("session_id")
  userId     String    @map("user_id")
  role       String    @default("member") @db.VarChar(20)
  nickname   String?   @db.VarChar(100)
  joinedAt   DateTime  @default(now()) @map("joined_at")
  lastReadAt DateTime? @map("last_read_at")

  session ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user    User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([sessionId, userId])
  @@map("chat_session_members")
}

model Message {
  id           String    @id @default(uuid())
  sessionId    String    @map("session_id")
  senderId     String?   @map("sender_id")
  content      String    @db.Text
  contentType  String    @default("text") @map("content_type") @db.VarChar(30)
  metadata     Json      @default("{}")
  isRecalled   Boolean   @default(false) @map("is_recalled")
  recalledAt   DateTime? @map("recalled_at")
  recalledById String?   @map("recalled_by_id")
  replyToId    String?   @map("reply_to_id")
  isPinned     Boolean   @default(false) @map("is_pinned")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  session    ChatSession     @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  sender     User?           @relation(fields: [senderId], references: [id], onDelete: SetNull)
  recalledBy User?           @relation("RecalledBy", fields: [recalledById], references: [id], onDelete: SetNull)
  replyTo    Message?        @relation("ReplyTo", fields: [replyToId], references: [id], onDelete: SetNull)
  replies    Message[]       @relation("ReplyTo")
  reactions  MessageReaction[]
  mentions   MessageMention[]

  @@index([sessionId, createdAt(sort: Desc)])
  @@index([senderId])
  @@map("messages")
}

model MessageReaction {
  id        String    @id @default(uuid())
  messageId String    @map("message_id")
  userId    String    @map("user_id")
  emoji     String    @db.VarChar(10)
  createdAt DateTime  @default(now()) @map("created_at")

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId, emoji])
  @@map("message_reactions")
}

model MessageMention {
  id        String    @id @default(uuid())
  messageId String    @map("message_id")
  userId    String    @map("user_id")
  createdAt DateTime  @default(now()) @map("created_at")

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("message_mentions")
}

model AgentMemory {
  id              String    @id @default(uuid())
  userId          String    @map("user_id")
  sessionId       String?   @map("session_id")
  memoryType      String    @map("memory_type") @db.VarChar(30)
  content         Json
  embedding       Float[]   @db.DoublePrecision
  importanceScore Float     @default(0.5) @map("importance_score")
  accessCount     Int       @default(0) @map("access_count")
  expiresAt       DateTime? @map("expires_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  user    User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  session ChatSession? @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([sessionId])
  @@map("agent_memories")
}

model AgentConversation {
  id             String    @id @default(uuid())
  userId         String    @map("user_id")
  sessionId      String?   @map("session_id")
  mode           String    @default("react") @db.VarChar(20)
  messages       Json      @default("[]")
  contextSummary String?   @map("context_summary") @db.Text
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  user    User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  session ChatSession?   @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  toolLogs AgentToolLog[]

  @@index([userId])
  @@map("agent_conversations")
}

model AgentToolLog {
  id              String    @id @default(uuid())
  conversationId  String?   @map("conversation_id")
  userId          String?   @map("user_id")
  toolName        String    @map("tool_name") @db.VarChar(100)
  toolInput       Json?     @map("tool_input")
  toolOutput      Json?     @map("tool_output")
  executionTimeMs Int?      @map("execution_time_ms")
  success         Boolean   @default(true)
  errorMessage    String?   @map("error_message") @db.Text
  createdAt       DateTime  @default(now()) @map("created_at")

  conversation AgentConversation? @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user         User?              @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([conversationId])
  @@index([createdAt(sort: Desc)])
  @@map("agent_tool_logs")
}

model AgentMetric {
  id          String    @id @default(uuid())
  userId      String?   @map("user_id")
  metricType  String    @map("metric_type") @db.VarChar(50)
  metricValue Float     @map("metric_value")
  metadata    Json      @default("{}")
  recordedAt  DateTime  @default(now()) @map("recorded_at")

  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("agent_metrics")
}

model KnowledgeBase {
  id            String    @id @default(uuid())
  name          String    @db.VarChar(200)
  description   String?   @db.Text
  ownerId       String?   @map("owner_id")
  isPublic      Boolean   @default(false) @map("is_public")
  config        Json      @default("{}")
  chunkSize     Int       @default(500) @map("chunk_size")
  chunkOverlap  Int       @default(50) @map("chunk_overlap")
  embeddingModel String   @default("text-embedding-3-small") @map("embedding_model") @db.VarChar(50)
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  owner         User?                @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  documents KnowledgeDocument[]
  chunks    KnowledgeChunk[]

  @@map("knowledge_bases")
}

model KnowledgeDocument {
  id              String    @id @default(uuid())
  kbId            String    @map("kb_id")
  fileName        String    @map("file_name") @db.VarChar(500)
  fileSize        Int?      @map("file_size")
  fileType        String?   @map("file_type") @db.VarChar(50)
  fileUrl         String?   @map("file_url") @db.Text
  status          String    @default("pending") @db.VarChar(20)
  totalChunks     Int       @default(0) @map("total_chunks")
  processedChunks Int       @default(0) @map("processed_chunks")
  errorMessage    String?   @map("error_message") @db.Text
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  knowledgeBase KnowledgeBase @relation(fields: [kbId], references: [id], onDelete: Cascade)

  @@map("knowledge_documents")
}

model KnowledgeChunk {
  id         String    @id @default(uuid())
  kbId       String    @map("kb_id")
  content    String    @db.Text
  embedding  Float[]   @db.DoublePrecision
  chunkIndex Int       @map("chunk_index")
  metadata   Json      @default("{}")
  createdAt  DateTime  @default(now()) @map("created_at")

  knowledgeBase KnowledgeBase @relation(fields: [kbId], references: [id], onDelete: Cascade)

  @@index([kbId])
  @@map("knowledge_chunks")
}

model FileUpload {
  id           String    @id @default(uuid())
  uploaderId   String?   @map("uploader_id")
  fileName     String    @map("file_name") @db.VarChar(500)
  fileSize     Int       @map("file_size")
  mimeType     String?   @map("mime_type") @db.VarChar(100)
  storagePath  String    @map("storage_path") @db.Text
  storageUrl   String?   @map("storage_url") @db.Text
  thumbnailUrl String?   @map("thumbnail_url") @db.Text
  createdAt    DateTime  @default(now()) @map("created_at")

  uploader User? @relation(fields: [uploaderId], references: [id], onDelete: SetNull)

  @@map("file_uploads")
}

model Notification {
  id        String    @id @default(uuid())
  userId    String    @map("user_id")
  type      String    @db.VarChar(50)
  title     String?   @db.VarChar(200)
  content   String?   @db.Text
  data      Json      @default("{}")
  isRead    Boolean   @default(false) @map("is_read")
  createdAt DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

model AuditLog {
  id           String    @id @default(uuid())
  userId       String?   @map("user_id")
  action       String    @db.VarChar(100)
  resourceType String?   @map("resource_type") @db.VarChar(50)
  resourceId   String?   @map("resource_id")
  ipAddress    String?   @map("ip_address") @db.VarChar(45)
  userAgent    String?   @map("user_agent") @db.Text
  metadata     Json      @default("{}")
  createdAt    DateTime  @default(now()) @map("created_at")

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@map("audit_logs")
}

model SystemSetting {
  key        String    @id @db.VarChar(100)
  value      Json
  description String?   @db.Text
  updatedAt  DateTime  @updatedAt @map("updated_at")

  @@map("system_settings")
}
