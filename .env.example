# ============================================================
# AI-Native Chat System - Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# ── Database ─────────────────────────────────────────────────
DB_PASSWORD=minichat_dev_password
DB_PORT=5432
# connection_limit=100 应对 200+ 并发写入，pool_timeout=30s 防止连接池耗尽时无限等待
DATABASE_URL=postgresql://minichat:${DB_PASSWORD}@localhost:${DB_PORT}/minichat?connection_limit=100&pool_timeout=30

# ── Redis ────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ── MinIO ────────────────────────────────────────────────────
MINIO_PORT=9000
MINIO_CONSOLE=9001
MINIO_USER=minioadmin
MINIO_PASSWORD=minioadmin

# ── JWT ──────────────────────────────────────────────────────
# IMPORTANT: Change these in production!
JWT_SECRET=change_this_to_a_random_64_char_string_in_production_minimum_32_chars
JWT_REFRESH_SECRET=change_this_to_another_random_64_char_string_in_production
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── DeepSeek ─────────────────────────────────────────────────
# Get your API key from https://platform.deepseek.com
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL_V3=deepseek-chat
DEEPSEEK_MODEL_R1=deepseek-reasoner

# ── Embedding ──────────────────────────────────────────────
# Provider: openai | deepseek
# OpenAI is the recommended provider. DeepSeek embedding endpoint returns 404.
EMBEDDING_PROVIDER=openai
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_EMBEDDING_URL=https://api.openai.com/v1/embeddings
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# DeepSeek Embedding (legacy, returns empty array if endpoint unavailable)
DEEPSEEK_EMBEDDING_URL=https://api.deepseek.com/v1/embeddings
DEEPSEEK_EMBEDDING_MODEL=deepseek-embedding

# ── AI Settings ───────────────────────────────────────────────
AI_DAILY_LIMIT=100
AI_STREAM_TIMEOUT=120000
AI_TEMPERATURE=0.7
AI_MAX_TOKENS_V3=4096
AI_MAX_TOKENS_R1=8192
# Enable DeepSeek thinking mode (reasoning chain before final answer)
AI_THINKING_ENABLED=false
# Thinking effort: low | medium | high | xhigh | max (low/medium->high, xhigh->max)
AI_REASONING_EFFORT=high

# ── CORS ──────────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:5173

# ── Rate Limiting ────────────────────────────────────────────
RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=100

# ── Message Queue ──────────────────────────────────────────
# 启用 BullMQ 消息写入队列（需要 Redis）。开启后消息先入队列再批量写入 DB。
QUEUE_ENABLED=false

# ── Ports ────────────────────────────────────────────────────
API_PORT=3000
WEB_PORT=80
NGINX_PORT=8080
NGINX_SSL_PORT=8443

# ── GitHub OAuth ───────────────────────────────────────────────
# Create OAuth App at: https://github.com/settings/developers
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret
GITHUB_CALLBACK_URL=http://localhost:3000/api/v1/auth/oauth/github/callback

# ── Google OAuth ───────────────────────────────────────────────
# Create OAuth App at: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:3000/api/v1/auth/oauth/google/callback

# ── Dev Tools ────────────────────────────────────────────────
PGADMIN_PASSWORD=admin
REDIS_CMD_PORT=8081
PGADMIN_PORT=5050
